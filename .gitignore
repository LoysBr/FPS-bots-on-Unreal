# Visual Studio 2015 user specific files
.vs/
ZulaOnUE/.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
ZulaOnUE/.vsconfig

# Precompiled Assets
ZulaOnUE/SourceArt/**/*.png
ZulaOnUE/SourceArt/**/*.tga

# Binary Files
ZulaOnUE/Binaries/*
ZulaOnUE/Binaries/**
ZulaOnUE/Plugins/**/Binaries/*

# Builds
ZulaOnUE/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!ZulaOnUE/Build/*/
ZulaOnUE/Build/*/**
!ZulaOnUE/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!ZulaOnUE/Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
ZulaOnUE/Saved/*

# Compiled source files for the engine to use
ZulaOnUE/Intermediate/*
ZulaOnUE/Plugins/**/Intermediate/*

# Cache files for the editor to use
ZulaOnUE/DerivedDataCache/*
